            "smoke",
            "shortcut",
            "determinism",
            "necessity"
          ],
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind",
        "description"
      ],
      "title": "ProbeSpec",
      "type": "object"
    },
    "ReferenceAction": {
      "additionalProperties": false,
      "properties": {
