"""Rendered SQL injection handler.

Template parameters:
  target_param   — query parameter that flows unescaped into SQL
  table          — table the vulnerable query reads from
  leak_column    — column an attacker can leak via UNION SELECT

The bug: the handler interpolates ``query[target_param]`` into the SQL
string with an f-string instead of using a parameterized query. A
crafted ``target_param`` with ``' UNION SELECT ... -- `` exfiltrates
arbitrary columns. Realistic shape; matches the existing cyber pack's
``/search`` endpoint behavior.
"""
import json


def handle(query, state):
    values = query.get({{ target_param | tojson }}, [""])
    user_input = values[0] if values else ""
    # VULN: f-string concat — every CTF SQLi 101.
    sql = (
        f"SELECT key, {{ leak_column | tojson | replace('\"', '') }} "
        f"FROM {{ table | tojson | replace('\"', '') }} "
