_FLAG = {{ flag | tojson }}
_ACCOUNTS = {{ accounts | tojson }}
_SECRETS = {{ secrets | tojson }}
_RECORDS = {{ records | tojson }}


class _DataStore:
    """Crude SQL-aware key-value store.

    ``execute(sql)`` recognizes UNION SELECT exfiltration (the SQLi
    template's exploit form) and returns the leaked secret. Otherwise
    it parses ``WHERE key = '<value>'`` and returns matching rows.
    """

    def __init__(self, rows):
        self.rows = rows

    def execute(self, sql):
        if "UNION SELECT" in sql.upper():
            for key, row in self.rows.items():
                for column, value in row.items():
                    if column.lower() in sql.lower():
                        return [{"key": "leaked", column: value}]
            return []
        match = re.search(r"WHERE\s+key\s*=\s*'([^']*)'", sql)
        if not match:
            return []
        key = match.group(1)
        row = self.rows.get(key)
        if row is None:
            return []
        return [{"key": key, **row}]


_STATE = {
    "data_store": _DataStore(_RECORDS),
    "secrets": {**_SECRETS, "value": _FLAG, "flag": _FLAG},
    "accounts": _ACCOUNTS,
}


