"""Generated multi-service webapp runtime.

Produced by ``cyber_webapp.codegen`` from a WorldGraph + manifest. Hand
edits will be overwritten by the next build. The flag value is NOT in
this file; ``seed.json`` is loaded into an in-memory SQLite database at
startup, then deleted from disk before the server begins accepting
requests.
"""
from __future__ import annotations

import argparse
import json
import re
import sqlite3
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.error import URLError
from urllib.parse import parse_qs, urlparse
from urllib.request import urlopen


# ---------------------------------------------------------------------------
# Bootstrap — load seed.json into in-memory SQLite, then unlink the seed.
# ---------------------------------------------------------------------------


def _load_seed_and_init_state(seed_path: Path) -> dict:
    raw = seed_path.read_text(encoding="utf-8")
    seed_path.unlink()
    payload = json.loads(raw)
    schema = payload["schema"]
    table = schema["table"]
    key_col = schema["key_column"]
    value_col = schema["value_column"]

    db = sqlite3.connect(":memory:", check_same_thread=False)
    db.row_factory = sqlite3.Row
    cursor = db.cursor()
    cursor.execute(
        f"CREATE TABLE {table} ({key_col} TEXT PRIMARY KEY, {value_col} TEXT)",
    )
    for record_key, fields in payload["records"].items():
        cursor.execute(
            f"INSERT INTO {table} ({key_col}, {value_col}) VALUES (?, ?)",
            (record_key, fields.get(value_col, "")),
        )
    db.commit()

    return {
        "db": db,
        "secrets": payload["secrets"],
        "accounts": payload["accounts"],
        "schema": schema,
    }


# ---------------------------------------------------------------------------
# Endpoint handlers — one per (service, endpoint).
# ---------------------------------------------------------------------------

{% for handler in handlers %}
# {{ handler.docstring }}
def {{ handler.name }}(query, state):
{{ handler.body }}

{% endfor %}

# ---------------------------------------------------------------------------
# Routing
# ---------------------------------------------------------------------------

_DISCOVERY = {{ discovery | tojson }}


def _index(query, state):
    """Public landing page — always available so probes have a route."""
    del query, state
    return 200, {"Content-Type": "text/html"}, _index_html()


def _index_html() -> bytes:
    title = _DISCOVERY.get("title", "Service")
    body = (
        f"<!doctype html><html><head><title>{title}</title></head>"
        f"<body><h1>{title}</h1><p>OK</p></body></html>"
    )
    return body.encode()


def _openapi(query, state):
    """Public OpenAPI-ish discovery endpoint."""
    del query, state
    return (
        200,
        {"Content-Type": "application/json"},
        json.dumps(_DISCOVERY).encode(),
    )


ROUTES = {
{% for route in routes %}
    {{ route.path | tojson }}: {{ route.handler }},
{% endfor %}
}
ROUTES.setdefault("/", _index)
ROUTES.setdefault("/openapi.json", _openapi)


class Handler(BaseHTTPRequestHandler):
    server: WebappServer  # type: ignore[name-defined]

    def do_GET(self) -> None:
        parsed = urlparse(self.path)
        query = parse_qs(parsed.query, keep_blank_values=True)
        handler = ROUTES.get(parsed.path)
        if handler is None:
            self.respond_simple(404, "text/plain", b"not found\n")
            return
        try:
            status, headers, body = handler(query, self.server.state)
        except Exception as exc:  # noqa: BLE001
            self.respond_simple(500, "text/plain", str(exc).encode())
            return
        self.respond(status, headers, body)

    def respond(self, status, headers, body):
        self.server.log_access(self.command, self.path, status)
        content_type = headers.get("Content-Type", "application/octet-stream")
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def respond_simple(self, status, content_type, body):
        self.respond(status, {"Content-Type": content_type}, body)

    def log_message(self, format, *args):
        return


class WebappServer(ThreadingHTTPServer):
    def __init__(self, address, *, log_path, state):
        super().__init__(address, Handler)
        self.log_path = log_path
        self.state = state

    def log_access(self, method, path, status):
        row = {"method": method, "path": path, "status": status}
        with self.log_path.open("a", encoding="utf-8") as handle:
            handle.write(json.dumps(row, sort_keys=True) + "\n")


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=0)
    parser.add_argument("--log", type=Path, required=True)
    parser.add_argument("--seed", type=Path, default=Path(__file__).parent / "seed.json")
    args = parser.parse_args()

    args.log.parent.mkdir(parents=True, exist_ok=True)
    args.log.write_text("", encoding="utf-8")

    state = _load_seed_and_init_state(args.seed)

    server = WebappServer((args.host, args.port), log_path=args.log, state=state)
    host, port = server.server_address[0], server.server_address[1]
    print(json.dumps({"host": host, "port": port}), flush=True)
    server.serve_forever()


if __name__ == "__main__":
    main()
